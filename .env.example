# Copy this file to ".env" and fill in real values.
# ".env" is git-ignored so real secrets never get committed.

# --- PostgreSQL database credentials ---
# These are used both by the "db" service in docker-compose.yml (to create
# the database) and by the FastAPI app (to connect to it).
POSTGRES_USER=lead_intel_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=lead_intelligence

# Full connection string the app uses to talk to Postgres via SQLAlchemy/asyncpg.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
# "db" is the hostname because that's the service name in docker-compose.yml -
# Docker lets containers reach each other by service name.
DATABASE_URL=postgresql+asyncpg://lead_intel_user:change_me@db:5432/lead_intelligence

# --- Anthropic (Claude) API ---
# Used by the background worker (app/worker.py) to score leads hot/warm/cold
# and draft outreach messages. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the Claude model the worker uses.
# ANTHROPIC_MODEL=claude-sonnet-5

# --- Mock service URLs (optional) ---
# The worker defaults to these Docker-network hostnames already, so you
# only need to set these if you're running a mock service somewhere else.
# PROPERTY_API_URL=http://property_api:8001
# PHONE_API_URL=http://phone_api:8002
# CRM_WEBHOOK_URL=http://crm_webhook:8003

# --- Slack alerting (optional) ---
# Incoming webhook URL the worker posts to when a lead permanently fails
# enrichment after DLQ_MAX_ATTEMPTS sweeps. If unset, the worker just logs
# a warning instead of sending an alert.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Automation kill switch ---
# Hard, infra-level override for the worker loop - set to "false" to force
# the worker to pause regardless of the runtime toggle (see
# POST /admin/kill-switch), e.g. if the admin API or database itself is the
# thing misbehaving. Requires a restart to change; for fast, no-redeploy
# control during an incident, use the admin endpoint instead.
AUTOMATION_ENABLED=true

# --- Admin API (basic auth) ---
# Protects POST/GET /admin/kill-switch. The endpoint returns 503 if
# ADMIN_PASSWORD is unset, rather than accepting any password.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# --- Future secrets go here as the project grows ---
# Example: API keys for lead data providers, mapping services, etc.
# SOME_THIRD_PARTY_API_KEY=
